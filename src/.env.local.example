# ============================================
# Firebase 설정 (Firebase Console에서 복사)
# https://console.firebase.google.com
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=여기에_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=여기에_AUTH_DOMAIN
NEXT_PUBLIC_FIREBASE_PROJECT_ID=여기에_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=여기에_STORAGE_BUCKET
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=여기에_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=여기에_APP_ID

# ============================================
# 카카오 설정 (카카오 디벨로퍼스에서 복사)
# https://developers.kakao.com
# ============================================
NEXT_PUBLIC_KAKAO_APP_KEY=여기에_카카오_JAVASCRIPT_KEY

# ============================================
# 시카(회장) 계정 설정
# Firebase에서 시카의 uid를 여기에 입력
# ============================================
NEXT_PUBLIC_SIKA_UID=여기에_시카_UID
